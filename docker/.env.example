# Copy to docker/.env and set values before running docker compose.
# Database credentials live in backend/.env (DATABASE_URL).

# Optional port overrides
# BACKEND_PORT=8000
# FRONTEND_PORT=3000

# Browser-facing backend URL (baked into frontend at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Allowed frontend origin for backend CORS
CORS_ORIGINS=http://localhost:3000
